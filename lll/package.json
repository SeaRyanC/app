{
  "name": "lll",
  "version": "3.1.1",
  "type": "module",
  "description": "Little League Lineup - Game scheduling tool for Little League baseball",
  "main": "src/index.tsx",
  "scripts": {
    "bundle": "esbuild src/index.tsx --bundle --outfile=../docs/lll/app.js --minify --sourcemap --define:process.env.NODE_ENV=\\\"production\\\" --define:process.browser=true --define:global=window --alias:stream=stream-browserify --alias:util=util --alias:buffer=buffer --inject:./src/polyfills.js --loader:.ts=ts --loader:.tsx=tsx",
    "check": "tsc --noEmit",
    "lint": "eslint src/",
    "local": "esbuild src/index.tsx --bundle --outfile=../docs/lll/app.js --sourcemap --servedir=../docs/lll --define:process.env.NODE_ENV=\\\"development\\\" --define:process.browser=true --define:global=window --alias:stream=stream-browserify --alias:util=util --alias:buffer=buffer --inject:./src/polyfills.js --loader:.ts=ts --loader:.tsx=tsx"
  },
  "keywords": [
    "baseball",
    "little-league",
    "lineup",
    "scheduler"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "blob-stream": "^0.1.3",
    "buffer": "^6.0.3",
    "events": "^3.3.0",
    "pdfkit-browserify": "^0.8.3-R2",
    "preact": "^10.28.2",
    "stream-browserify": "^3.0.0",
    "util": "^0.12.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.27.0",
    "@types/node": "^22.15.29",
    "@types/pdfkit": "^0.17.4",
    "esbuild": "^0.27.2",
    "eslint": "^9.27.0",
    "pdfkit": "^0.17.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.32.1"
  }
}
